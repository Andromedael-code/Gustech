# =========================================================
# Git / repositório local
# =========================================================
.git/
.gitignore~

# =========================================================
# Dependências Node.js
# =========================================================
node_modules/
backend/node_modules/

# =========================================================
# Variáveis de ambiente
# =========================================================
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# =========================================================
# Credenciais / secrets
# NUNCA subir chaves privadas Firebase / Google Cloud
# =========================================================
backend/*firebase-adminsdk*.json
backend/*service-account*.json
backend/*serviceAccount*.json
backend/google-credentials.json
backend/credentials.json
*.pem
*.key
*.p12

# =========================================================
# Banco de dados local
# =========================================================
*.db
*.sqlite
*.sqlite3
*.db-journal
database/
backend/database/
data/

# =========================================================
# Logs
# =========================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
backend/*.log

# =========================================================
# Builds / arquivos gerados
# =========================================================
dist/
build/
out/
release/
coverage/
.vite/
.cache/
.tmp/
temp/
tmp/

# =========================================================
# Uploads / arquivos locais do app
# =========================================================
uploads/
backend/uploads/
storage/
backend/storage/

# =========================================================
# Sistema operacional
# =========================================================
.DS_Store
Thumbs.db
desktop.ini

# =========================================================
# Editores / IDEs
# =========================================================
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo

# =========================================================
# Ferramentas locais
# =========================================================
.openclaude/
.openclaude-profile.json
.codex-app.log
