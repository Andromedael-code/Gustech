# Servidor
NODE_ENV=development
PORT=8080
DB_CLIENT=sqlite

# CORS (separados por virgula)
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,http://localhost:5501,http://127.0.0.1:5501,http://localhost:4182,http://127.0.0.1:4182,http://localhost:5173,http://127.0.0.1:5173

# SQLite local (padrao em desenvolvimento, nao precisa Docker)
SQLITE_PATH=data/gustech.sqlite

# MySQL (opcional: use DB_CLIENT=mysql)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=gustech
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_CONNECTION_LIMIT=10

# Admins (emails separados por virgula)
ADMIN_ALLOWLIST=admin@gustech.com

# Twilio (opcional, para verificacao por SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
SMS_DEFAULT_COUNTRY_CODE=55

# Firebase
FIREBASE_PROJECT_ID=gustavo-gaymer-loja
# Base64 do JSON de service account. Alternativa: usar GOOGLE_APPLICATION_CREDENTIALS.
FIREBASE_SERVICE_ACCOUNT_JSON=
